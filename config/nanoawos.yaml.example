station:
  id: "YOUR_STATION_ID"
  icao: "XXXX"
  name: "your station name"
  elevation_ft: 230
  runways: [15, 33]

weather:
  api_key: ""
  update_interval_sec: 300
  api_url: "https://api.weather.com/v2/pws/observations/current"

tts:
  engine: "piper"
  piper_model: "/mnt/p4/models/en_US-ryan-medium.onnx"
  output_dir: "/run/nanoawos"    # tmpfs ramdisk -- no SD card wear, lost on reboot (regenerated)

audio:
  input_mode: "analog"     # "analog" (audio cable) or "sdr" (RTL-SDR)
  mpd_host: "localhost"
  mpd_port: 6600
  gpio_pin: 201
  alsa_device: "hw:2,0"
  filter_cutoff_hz: 300    # High-pass cutoff for buzz removal
  noise_reduction: 0.3     # Sox noisered amount (0.0-1.0)
  gain_db: 0               # Volume boost in dB (6=2x louder)
  compand: false           # Auto-level voice compression
  ptt_pre_delay_ms: 500    # Silence lead-in before audio playback

# SDR receiver (RTL-SDR) - alternative to analog audio cable for receiving
sdr:
  frequency_mhz: 122.5      # Aviation frequency in MHz (118.000-136.975)
  gain: 40                   # Tuner gain (0-50, higher = more sensitive but more noise)
  squelch: 50                # Squelch level (0=off, higher = more aggressive)
  ppm_correction: 0          # Frequency correction in PPM (measure with rtl_test -p)
  sample_rate: 12000         # Audio sample rate (12000 is good for voice)
  device_index: 0            # RTL-SDR device index (if multiple dongles)
  # SDR audio processing (separate from analog -- SDR is cleaner, needs less filtering)
  filter_cutoff_hz: 200      # Lower cutoff OK for SDR (no cable buzz)
  noise_reduction: 0         # Usually 0 for SDR (no analog noise)
  gain_db: 0                 # Volume boost if needed
  compand: false             # Auto-level voice

tap:
  short_clicks: 4
  long_clicks: 6
  calibration_seconds: 3
  device_name: ""
  # Timing constraints (ms) for debounced state machine
  min_click_ms: 50       # Reject noise spikes shorter than this
  max_click_ms: 2000     # Reject voice/continuous signal longer than this
  min_gap_ms: 150        # Minimum silence between clicks (debounce)
  max_gap_ms: 2500       # Timeout: sequence complete after this silence
  # Fallback threshold multipliers (used before self-learning has enough data)
  high_mult: 50          # t_high = noise_floor * high_mult
  low_mult: 10           # t_low = noise_floor * low_mult

# Click actions: map click counts (4-12) to actions
# Types: weather_wind, weather_full, tts, mqtt, none
click_actions:
  4:
    label: "Wind report"
    type: "weather_wind"
  6:
    label: "Full weather"
    type: "weather_full"
  5:
    label: "5-click MQTT"
    type: "mqtt"
    topic: "nanoawos/clicks/5"
  7:
    label: "7-click MQTT"
    type: "mqtt"
    topic: "nanoawos/clicks/7"
  8:
    label: "Custom TTS"
    type: "tts"
    text: "{{ station.name }}, {{ time.zulu }}, wind {{ weather.wind }}"
  9:
    label: "9-click MQTT"
    type: "mqtt"
    topic: "nanoawos/clicks/9"
  10:
    label: "10-click MQTT"
    type: "mqtt"
    topic: "nanoawos/clicks/10"
  11:
    label: "11-click MQTT"
    type: "mqtt"
    topic: "nanoawos/clicks/11"
  12:
    label: "12-click MQTT"
    type: "mqtt"
    topic: "nanoawos/clicks/12"

# Custom data sources for Jinja2 templates in TTS actions
# Each source is fetched via HTTP GET and cached. Available as {{ source_name.field }}
data_sources: []
  # Example:
  # - name: "metar_api"
  #   url: "https://aviationweather.gov/api/data/metar?ids=XXXX&format=json"
  #   cache_ttl: 300
  #   headers:
  #     Authorization: "Bearer your-token"
  # - name: "notam"
  #   url: "https://api.example.com/notams?icao=XXXX"
  #   cache_ttl: 3600

# Transcription reactions: trigger actions when keywords appear in transcribed radio text
# Same action types as click_actions: tts, mqtt, weather_full, weather_wind, none
# Extra Jinja2 context: {{ transcript.text }}, {{ transcript.action }}
transcription_reactions:
  - label: "Emergency detected"
    match: "mayday|pan pan|emergency"
    match_field: "text"
    type: "mqtt"
    topic: "nanoawos/emergency"
    payload: '{"text": "{{ transcript.text }}", "time": "{{ time.zulu }}"}'
  - label: "Landing announced"
    match: "final|landing|runway"
    match_field: "text"
    type: "mqtt"
    topic: "nanoawos/traffic/landing"
  - label: "Traffic in pattern"
    match: "downwind|crosswind|base|pattern"
    match_field: "text"
    type: "mqtt"
    topic: "nanoawos/traffic/pattern"
  # Example: TTS read-back on any actionable item detected by GPT
  # - label: "Action detected"
  #   match: ".*"
  #   match_field: "action"
  #   type: "tts"
  #   tts_engine: "cloud"
  #   text: "Traffic alert. {{ transcript.action }}"

mqtt:
  enabled: false
  broker: "localhost"
  port: 1883
  username: ""
  password: ""

web:
  enabled: true
  host: "0.0.0.0"
  port: 8080

oled:
  enabled: true

transcribe:
  enabled: false
  openai_api_key: ""
  model: "whisper-1"
  language: "auto"
  min_duration_sec: 0.5
  max_duration_sec: 60
  silence_blocks: 15
  log_file: "/tmp/nanoawos_transcriptions.json"
  max_log_entries: 200
  extract_actions: true
  action_model: "gpt-4o-mini"
  action_prompt: "You are an aviation radio communications analyst at a small uncontrolled airfield. Extract actionable items from this pilot radio transmission. Always reply in English. Be brief. If nothing actionable, reply with just 'No action'. Actionable means: aircraft position reports, landing/takeoff intentions, emergency calls, requests, circuit/pattern announcements."
